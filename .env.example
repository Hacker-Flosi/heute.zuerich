# .env.local — heute.zürich Umgebungsvariablen
# Diese Datei NICHT ins Git committen!

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-write-token

# Anthropic (für AI-Kuratierung)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Eventfrog API
EVENTFROG_API_KEY=your-eventfrog-api-key

# Meta Graph API (für Instagram)
META_ACCESS_TOKEN=your-meta-access-token
INSTAGRAM_ACCOUNT_ID=your-instagram-account-id

# imgbb — Bild-Upload für Instagram Posts (kostenlos: imgbb.com → Account → API)
IMGBB_API_KEY=your-imgbb-api-key

# Spotify API (für Artist-Links bei Konzert-Events)
# developer.spotify.com → App erstellen → Client ID + Secret
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Vercel Cron (Security)
CRON_SECRET=your-random-cron-secret
